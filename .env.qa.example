# Copy to a local untracked file, export these variables, or add matching GitHub Actions secrets.
# These accounts should be dedicated QA users because workflow tests may create labeled QA data.

QA_BASE_URL=https://trustedbums.com
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

QA_ADMIN_EMAIL=admin-test@example.com

QA_CLIENT_ADMIN_EMAIL=client-admin-test@example.com

QA_CLIENT_FINANCE_EMAIL=client-finance-test@example.com

QA_CLIENT_MEMBER_EMAIL=client-member-test@example.com

QA_BUM_EMAIL=bum-test@example.com

# Use required for release workflows, optional for local smoke, or skip only for explicitly scoped runs.
QA_EXTENSION_API_EXPECTATION=required
# Required when QA_EXTENSION_API_EXPECTATION=required or QA_EXTENSION_API_BASE_URL is set. Use a dedicated QA token only.
QA_EXTENSION_API_BASE_URL=https://vaoqvtxqvbptyxddpoju.supabase.co/functions/v1/extension-api-v1
QA_EXTENSION_API_TOKEN=

# Necessary operational performance monitoring.
# Use deployment-provider secrets or local QA env values; do not commit real tokens.

RewriteEngine On
RewriteBase /

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://clerk.trustedbums.com https://*.clerk.accounts.dev https://*.clerk.com https://static.cloudflareinsights.com https://www.googletagmanager.com; connect-src 'self' https://trustedbums.com https://*.trustedbums.com https://vaoqvtxqvbptyxddpoju.supabase.co wss://vaoqvtxqvbptyxddpoju.supabase.co https://*.clerk.accounts.dev https://*.clerk.com https://api.clerk.com https://graph.microsoft.com https://challenges.cloudflare.com https://cloudflareinsights.com https://www.google-analytics.com https://region1.google-analytics.com https://www.googletagmanager.com; frame-src https://challenges.cloudflare.com https://clerk.trustedbums.com https://*.clerk.accounts.dev https://*.clerk.com; worker-src 'self' blob:; form-action 'self'"
</IfModule>

# Serve crawler-facing files as static assets with explicit content types.
AddType application/xml .xml
AddType text/plain .txt
RewriteRule ^(sitemap\.xml|robots\.txt)$ - [L]

# Keep the pre-store extension package off the public site.
RewriteRule ^downloads/trustedbums-extension\.zip$ - [F,L]

# Let Apache serve real files and directories directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Serve generated public-route metadata snapshots before the SPA fallback.
RewriteRule ^(bums|login|privacy-policy)$ $1/index.html [L]
RewriteRule ^legal/(terms-of-service|cookie-policy|dpa|subprocessors|security|acceptable-use|recording-transcription-notice|data-retention|client-agreement|bum-agreement)$ legal/$1/index.html [L]

# Route all SPA requests back to the React entrypoint.
RewriteRule ^ index.html [L]

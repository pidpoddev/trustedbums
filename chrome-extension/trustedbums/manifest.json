{
  "manifest_version": 3,
  "name": "Trusted Bums",
  "description": "Send user-confirmed page captures to Trusted Bums.",
  "version": "1.1.0",
  "minimum_chrome_version": "110",
  "action": {
    "default_title": "Send to Trusted Bums",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": ["activeTab", "cookies", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://vaoqvtxqvbptyxddpoju.supabase.co/*",
    "https://trustedbums.com/*",
    "$CLERK_FRONTEND_API/*",
    "$CLERK_SYNC_HOST/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*", "https://www.linkedin.com/company/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
